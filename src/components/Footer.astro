    <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-muted/60 text-sm tracking-wide">
        &copy; {currentYear} Kazend. All rights reserved.
      </p>
      <div class="flex items-center gap-8">
        <a href="#" class="text-muted/60 hover:text-gold text-sm transition-colors duration-300">Privacy Policy</a>
        <a href="#" class="text-muted/60 hover:text-gold text-sm transition-colors duration-300">Terms of Service</a>
        <a href="#" class="text-muted/60 hover:text-gold text-sm transition-colors duration-300">Cookie Policy</a>
      </div>
    </div>
  </div>
</footer>
