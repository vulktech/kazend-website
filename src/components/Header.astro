---
interface Props {
  launchYear?: string;
}

const { launchYear = "2026" } = Astro.props;
---

<header class="p-4 md:p-6 lg:p-8">
  <div class="max-w-7xl mx-auto flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 animate-slide-in group">
      <div class="w-11 h-11 border border-gold/30 flex items-center justify-center relative overflow-hidden transition-all duration-300 group-hover:border-gold/60">
        <div class="absolute inset-0 bg-gold/5 transition-all duration-300 group-hover:bg-gold/10"></div>
        <svg class="w-5 h-5 text-gold relative z-10 transition-transform duration-300 group-hover:scale-110" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
        </svg>
      </div>
      <span class="text-xl font-display font-semibold tracking-wide text-cream transition-colors duration-300 group-hover:text-gold">KAZEND</span>
    </a>

    <!-- Launch Badge -->
    <div class="hidden md:flex items-center gap-2 animate-fade-in delay-300">
      <span class="w-2 h-2 bg-gold rounded-full animate-pulse-glow"></span>
      <span class="text-muted text-sm font-medium tracking-wider uppercase">Launching {launchYear}</span>
    </div>
  </div>
</header>
